OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LLM_MODEL=ministral-3:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
# Set to TRUE to use OpenRouter (cloud) instead of Ollama for LLM calls
ENABLED_CLOUD=FALSE
OPENROUTER_API_KEY=
